PROJECT_NAME=bizgital-marketing-report

# MySQL
MYSQL_DATABASE=bizgital_marketing_report
MYSQL_USER=marketing
MYSQL_PASSWORD=marketing
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306

# App ports
BACKEND_PORT=3003
FRONTEND_PORT=3200
API_PREFIX=api

# Public app URLs (set to your real domain in production)
APP_ORIGIN=http://localhost:3200
NEXT_PUBLIC_API_BASE_URL=http://localhost:3003/api

# Auth secrets (must be long random values in production)
AUTH_SESSION_SECRET=change-this-in-production
INTERNAL_API_AUTH_SECRET=change-this-to-a-different-production-secret

# Microsoft login (frontend runtime)
MICROSOFT_CLIENT_ID=change-this
MICROSOFT_CLIENT_SECRET=change-this
MICROSOFT_TENANT_ID=change-this
# For production set to your real domain callback, for local use localhost:3200.
MICROSOFT_REDIRECT_URI=http://localhost:3200/api/auth/microsoft/callback

# Storage (MinIO for local, Spaces/S3 for production)
IMPORT_STORAGE_DIR=storage/imports
MEDIA_S3_ENDPOINT=http://localhost:9000
MEDIA_S3_REGION=us-east-1
MEDIA_S3_BUCKET=report-media
MEDIA_S3_ACCESS_KEY=minioadmin
MEDIA_S3_SECRET_KEY=minioadmin
MEDIA_S3_FORCE_PATH_STYLE=true
MEDIA_S3_PUBLIC_BASE_URL=http://localhost:9000/report-media
MEDIA_UPLOAD_MAX_BYTES=10485760
MEDIA_PRESIGN_EXPIRES_SECONDS=900
MEDIA_READ_PRESIGN_EXPIRES_SECONDS=120
MEDIA_ORPHAN_CLEANUP_ENABLED=true
MEDIA_ORPHAN_CLEANUP_INTERVAL_HOURS=24
MEDIA_ORPHAN_CLEANUP_INITIAL_DELAY_MINUTES=5
MEDIA_ORPHAN_CLEANUP_MAX_DELETE_PER_RUN=500
MEDIA_ORPHAN_CLEANUP_MIN_AGE_HOURS=168
