PROJECT_NAME=bizgital-marketing-report

MYSQL_DATABASE=bizgital_marketing_report
MYSQL_USER=marketing
MYSQL_PASSWORD=change-this
MYSQL_ROOT_PASSWORD=change-this

BACKEND_PORT=3003
FRONTEND_PORT=3200
API_PREFIX=api
APP_ORIGIN=https://report.example.com
NEXT_PUBLIC_API_BASE_URL=https://report.example.com/api
AUTH_SESSION_SECRET=change-this-in-production

# Storage:
# - For DigitalOcean Spaces / S3-compatible production, use real endpoint + credentials.
# - For local MinIO in production host, run compose with --profile with-minio and set endpoint to http://minio:9000
MEDIA_S3_ENDPOINT=https://sgp1.digitaloceanspaces.com
MEDIA_S3_REGION=sgp1
MEDIA_S3_BUCKET=report-media
MEDIA_S3_ACCESS_KEY=change-this
MEDIA_S3_SECRET_KEY=change-this
MEDIA_S3_FORCE_PATH_STYLE=false
MEDIA_S3_PUBLIC_BASE_URL=https://cdn.example.com/report-media
MEDIA_UPLOAD_MAX_BYTES=10485760
MEDIA_PRESIGN_EXPIRES_SECONDS=900
MEDIA_READ_PRESIGN_EXPIRES_SECONDS=120
MEDIA_ORPHAN_CLEANUP_ENABLED=true
MEDIA_ORPHAN_CLEANUP_INTERVAL_HOURS=24
MEDIA_ORPHAN_CLEANUP_INITIAL_DELAY_MINUTES=5
MEDIA_ORPHAN_CLEANUP_MAX_DELETE_PER_RUN=500
MEDIA_ORPHAN_CLEANUP_MIN_AGE_HOURS=168
