{
  "manifest_version": 3,
  "name": "BIZGITAL Insight Capture Bridge",
  "version": "0.1.0",
  "description": "Bridge between BIZGITAL UI and browser-native Facebook insight capture.",
  "homepage_url": "https://report.bizgital.com/",
  "permissions": [
    "tabs",
    "scripting",
    "downloads",
    "activeTab",
    "debugger",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/bizgital-16.png",
    "32": "icons/bizgital-32.png",
    "48": "icons/bizgital-48.png",
    "128": "icons/bizgital-128.png"
  },
  "action": {
    "default_title": "BIZGITAL Insight Capture",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/bizgital-16.png",
      "32": "icons/bizgital-32.png",
      "48": "icons/bizgital-48.png",
      "128": "icons/bizgital-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://localhost:*/*",
        "http://127.0.0.1/*",
        "http://127.0.0.1:*/*",
        "https://*/*"
      ],
      "js": [
        "content-bridge.js"
      ],
      "run_at": "document_start"
    }
  ]
}
