{
  "name": "bizgital-marketing-report",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "docker:up": "docker compose up --build",
    "docker:prod": "docker compose up -d --build",
    "docker:local": "docker compose -f docker-compose.local.yml up --build",
    "docker:local:detached": "docker compose -f docker-compose.local.yml up -d --build"
  }
}
